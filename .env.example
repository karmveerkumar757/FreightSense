# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Hugging Face Offline Mode (to speed up model initialization)
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1

# Twilio Configuration (Optional - for SMS/WhatsApp Alerts)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=your_twilio_phone_number_here

# Telegram Bot Integration (Optional - for Free Telegram Alerts)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
